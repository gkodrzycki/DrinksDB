[
    {
        "id": "mojito",
        "name": "Mojito",
        "image": "/images/mojito.jpg",
        "category": "Cocktail",
        "alcohol_type": [
            "Rum"
        ],
        "ingredients": [
            "2 oz White rum",
            "1 oz Fresh lime juice",
            "2 tsp Sugar",
            "6-8 Fresh mint leaves",
            "Soda water",
            "Ice cubes"
        ],
        "instructions": [
            "Muddle mint leaves with sugar and lime juice in a glass",
            "Fill the glass with ice cubes",
            "Pour the rum over the ice",
            "Top with soda water",
            "Stir gently and garnish with mint sprig"
        ],
        "glass_type": "Highball glass",
        "flavors": [
            "Fresh",
            "Minty",
            "Citrus",
            "Refreshing"
        ],
        "garnish": "Mint sprig and lime wheel"
    },
    {
        "id": "old-fashioned",
        "name": "Old Fashioned",
        "image": "/images/old-fashioned.jpg",
        "category": "Cocktail",
        "alcohol_type": [
            "Whisky"
        ],
        "ingredients": [
            "2 oz Bourbon or Rye whisky",
            "1 Sugar cube",
            "2-3 dashes Angostura bitters",
            "Orange peel",
            "Ice cubes"
        ],
        "instructions": [
            "Place sugar cube in glass and saturate with bitters",
            "Add a splash of water and muddle until dissolved",
            "Fill the glass with ice cubes",
            "Add whisky and stir gently",
            "Express orange peel over the drink and drop it in"
        ],
        "glass_type": "Old Fashioned glass",
        "flavors": [
            "Strong",
            "Bitter",
            "Sophisticated"
        ],
        "garnish": "Orange peel and cherry"
    },
    {
        "id": "margarita",
        "name": "Margarita",
        "image": "/images/margarita.jpg",
        "category": "Cocktail",
        "alcohol_type": [
            "Tequila"
        ],
        "ingredients": [
            "2 oz Tequila",
            "1 oz Cointreau or Triple Sec",
            "1 oz Fresh lime juice",
            "Salt for rim",
            "Ice cubes"
        ],
        "instructions": [
            "Rim the glass with salt",
            "Add tequila, Cointreau, and lime juice to a shaker with ice",
            "Shake vigorously for 15 seconds",
            "Strain into the prepared glass over fresh ice"
        ],
        "glass_type": "Margarita glass",
        "flavors": [
            "Tangy",
            "Citrus",
            "Refreshing",
            "Salty"
        ],
        "garnish": "Lime wheel"
    },
